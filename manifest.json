          {"path": "unet/Flux/flux1-dev-kontext_fp8_scaled.safetensors", "url": null, "page_url": "https://huggingface.co/black-forest-labs/FLUX.1-Kontext-dev", "size_mb": 11904, "vram_min_gb": 12, "optional": true, "note": "Flux 1 Dev Kontext fp8 — alternative for Kontext workflows"}
