{
  "version": "1.0",
  "name": "Spellcaster",
  "description": "AI superpowers for GIMP 3 and Darktable — image generation, inpainting, face swap, background removal, video generation, and more.",
  "repo": "https://github.com/laboratoiresonore/spellcaster",

  "custom_nodes": {
    "ComfyUI-GGUF": {
      "repo": "https://github.com/city96/ComfyUI-GGUF",
      "provides": ["CLIPLoaderGGUF", "UnetLoaderGGUF"],
      "required_by": ["wan_i2v"]
    },
    "ComfyUI-VideoHelperSuite": {
      "repo": "https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite",
      "provides": ["VHS_VideoCombine"],
      "required_by": ["wan_i2v"]
    },
    "ComfyUI-RIFE": {
      "repo": "https://github.com/dajes/frame-interpolation-pytorch",
      "alt_repo": "https://github.com/Fannovel16/ComfyUI-Frame-Interpolation",
      "provides": ["RIFE VFI"],
      "required_by": ["wan_i2v"]
    },
    "comfyui-reactor-node": {
      "repo": "https://github.com/Gourieff/comfyui-reactor-node",
      "provides": ["ReActorFaceSwap", "ReActorLoadFaceModel", "ReActorFaceSwapOpt", "ReActorOptions", "ReActorFaceBoost"],
      "required_by": ["face_swap_reactor"]
    },
    "comfyui-mtb": {
      "repo": "https://github.com/melMass/comfyui-mtb",
      "provides": ["Load Face Analysis Model (mtb)", "Load Face Swap Model (mtb)", "Face Swap (mtb)"],
      "required_by": ["face_swap_mtb"]
    },
    "ComfyUI_IPAdapter_plus": {
      "repo": "https://github.com/cubiq/ComfyUI_IPAdapter_plus",
      "provides": ["IPAdapterUnifiedLoaderFaceID", "IPAdapterFaceID"],
      "required_by": ["faceid_img2img"]
    },
    "PuLID_ComfyUI": {
      "repo": "https://github.com/cubiq/PuLID_ComfyUI",
      "provides": ["PulidFluxModelLoader", "PulidFluxEvaClipLoader", "PulidFluxInsightFaceLoader", "ApplyPulidFlux"],
      "required_by": ["pulid_flux"]
    },
    "ComfyUI_GetImageSize": {
      "repo": "https://github.com/IuvenisSapworworiens/ComfyUI_GetImageSize",
      "alt_repo": "https://github.com/kijai/ComfyUI-KJNodes",
      "provides": ["GetImageSize+"],
      "required_by": ["img2img", "inpaint", "face_swap_reactor", "face_swap_mtb"]
    },
    "ComfyUI-RTX-Remix": {
      "repo": "https://github.com/NVlabs/ComfyUI-RTXVideoSuperResolution",
      "alt_repo": "https://github.com/pifroggi/ComfyUI-RTXVideoSuperResolution",
      "provides": ["RTXVideoSuperResolution"],
      "required_by": ["wan_i2v"],
      "note": "Requires NVIDIA RTX GPU with Tensor cores"
    },
    "ComfyUI-REMBG": {
      "repo": "https://github.com/Jcd1230/rembg-comfyui-node",
      "alt_repo": "https://github.com/Loewen-Hob/rembg-comfyui-node-better",
      "provides": ["Image Rembg (Remove Background)"],
      "required_by": ["rembg"],
      "note": "The isnet-general-use model is downloaded automatically on first use"
    },
    "ComfyUI-LaMa": {
      "repo": "https://github.com/mlinmg/ComfyUI-LaMA-Preprocessor",
      "alt_repo": "https://github.com/Acly/comfyui-inpaint-nodes",
      "provides": ["LaMaInpaint"],
      "required_by": ["lama_remove"]
    },
    "ComfyUI-essentials": {
      "repo": "https://github.com/cubiq/ComfyUI_essentials",
      "provides": ["ImageApplyLUT+"],
      "required_by": ["lut_grading"]
    },
    "comfyui-controlnet-aux": {
      "repo": "https://github.com/Fannovel16/comfyui_controlnet_aux",
      "provides": ["CannyEdgePreprocessor", "MiDaS-DepthMapPreprocessor", "DWPreprocessor", "ScribblePreprocessor", "LineArtPreprocessor"],
      "required_by": ["controlnet", "colorize"]
    },
    "ComfyUI-IC-Light": {
      "repo": "https://github.com/kijai/ComfyUI-IC-Light-Wrapper",
      "alt_repo": "https://github.com/huchenlei/ComfyUI-IC-Light",
      "provides": ["LoadAndApplyICLightUnet", "ICLightConditioning"],
      "required_by": ["iclight"]
    },
    "ComfyUI-SUPIR": {
      "repo": "https://github.com/kijai/ComfyUI-SUPIR",
      "provides": ["SUPIR_model_loader", "SUPIR_encode", "SUPIR_sample", "SUPIR_decode"],
      "required_by": ["supir"]
    },
    "ComfyUI-WD14-Tagger": {
      "repo": "https://github.com/pythongosssss/ComfyUI-WD14-Tagger",
      "provides": ["WD14Tagger|pysssss"],
      "required_by": ["img2img"]
    }
  },

