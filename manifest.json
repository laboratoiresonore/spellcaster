    "face_swap_reactor": {
      "vram_min_gb": 4,
      "label": "Face Swap (ReActor)",
      "description": "Swap faces between images using ReActor",
      "plugins": ["gimp", "darktable"],
      "models": {
        "face_restore": [
          {"path": "facerestore_models/codeformer-v0.1.0.pth", "url": "https://github.com/sczhou/CodeFormer/releases/download/v0.1.0/codeformer.pth", "size_mb": 376, "optional": false, "note": "CodeFormer face restoration (required by ReActor)"},
          {"path": "facerestore_models/GFPGANv1.3.pth", "url": "https://github.com/TencentARC/GFPGAN/releases/download/v1.3.0/GFPGANv1.3.pth", "size_mb": 332, "optional": true, "note": "GFPGAN v1.3"},
          {"path": "facerestore_models/GFPGANv1.4.pth", "url": "https://github.com/TencentARC/GFPGAN/releases/download/v1.3.4/GFPGANv1.4.pth", "size_mb": 349, "optional": true, "note": "GFPGAN v1.4"}
        ],
        "note": "ReActor downloads its own insightface/inswapper model on first use. CodeFormer is required for face restoration."
      },
      "custom_nodes": ["comfyui-reactor-node", "ComfyUI_GetImageSize"]
    },

    "face_swap_mtb": {
      "vram_min_gb": 4,
      "label": "Face Swap (MTB)",
      "description": "Alternative face swap using comfyui-mtb",
      "plugins": ["gimp", "darktable"],
      "models": {
        "note": "MTB face swap models are downloaded automatically by the node on first use."
      },
      "custom_nodes": ["comfyui-mtb", "ComfyUI_GetImageSize"]
    },

    "faceid_img2img": {
      "vram_min_gb": 8,
      "label": "FaceID Image-to-Image",
      "description": "Generate images preserving face identity using IPAdapter FaceID (GIMP only)",
      "plugins": ["gimp"],
      "models": {
        "note": "IPAdapter FaceID models are managed by the IPAdapter node. It will prompt you to download the correct model on first use."
      },
      "custom_nodes": ["ComfyUI_IPAdapter_plus"]
    },

